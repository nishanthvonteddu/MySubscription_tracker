APP_NAME=MySubscription Tracker API
ENVIRONMENT=development
API_V1_PREFIX=/api/v1
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/mysubscription_tracker
BACKEND_CORS_ORIGINS=["http://localhost:3000"]
LOG_LEVEL=INFO
JSON_LOGS=false
SENTRY_DSN=
STORAGE_BACKEND=local
LOCAL_STORAGE_PATH=./storage
EMAIL_BACKEND=console
EMAIL_FROM=no-reply@mysubscription-tracker.local
APP_BASE_URL=http://localhost:8000
AWS_REGION=us-east-1
AWS_BUCKET_NAME=
